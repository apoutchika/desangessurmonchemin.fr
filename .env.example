# Mailjet (pour l'envoi d'emails)
# Créer un compte sur https://www.mailjet.com
MAILJET_API_KEY=your_api_key
MAILJET_SECRET_KEY=your_secret_key
MAILJET_SENDER_EMAIL=contact@votredomaine.fr
CONTACT_EMAIL=votre-email@exemple.fr

# Google reCAPTCHA v2
# Créer sur https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Salt pour anonymisation des IPs (téléchargements et likes)
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_SALT=

# Stripe (pour les dons)
# Créer un compte sur https://stripe.com
# Clés disponibles dans Dashboard > Developers > API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
